@page "/admin"
@using LoansApp.Domain.Enums
@using LoansApp.Web.Models
@using LoansApp.Web.Services
@rendermode InteractiveServer
@inject LoanService LoanService

<h3>Administración de Préstamos</h3>

@if (loans == null)
{
    <p><em>Cargando préstamos...</em></p>
}
else if (!loans.Any())
{
    <p>No hay préstamos registrados.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Monto</th>
                <th>Plazo</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var loan in loans)
            {
                <tr>
                    <td>@loan.Amount</td>
                    <td>@loan.Term</td>
                    <td>@loan.Status</td>
                    <td>
                        @if (loan.Status == LoanStatus.Pending)
                        {
                            <button class="btn btn-success btn-sm me-2"
                                    @onclick="() => Approve(loan.Id)">
                                ✔ Aprobar
                            </button>

                            <button class="btn btn-danger btn-sm"
                                    @onclick="() => Reject(loan.Id)">
                                ✖ Rechazar
                            </button>
                        }
                        else
                        {
                            <span class="text-muted">Sin acciones</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<LoanModel> loans = new();
    private bool _loaded = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_loaded)
        {
            _loaded = true;
            await LoadLoans();
            StateHasChanged();
        }
    }

    private async Task LoadLoans()
    {
        loans = await LoanService.GetAllLoans() ?? new List<LoanModel>();
    }

    // Acción aprobar
    private async Task Approve(Guid id)
    {
        await LoanService.ApproveLoan(id);
        await LoadLoans();
        StateHasChanged();
    }

    // Acción rechazar
    private async Task Reject(Guid id)
    {
        await LoanService.RejectLoan(id);
        await LoadLoans();
        StateHasChanged();
    }

    // Estilos dinámicos
    private string GetStatusBadge(LoanStatus status)
    {
        return status switch
        {
            LoanStatus.Pending => "badge bg-warning text-dark",
            LoanStatus.Approved => "badge bg-success",
            LoanStatus.Rejected => "badge bg-danger",
            _ => "badge bg-secondary"
        };
    }
}