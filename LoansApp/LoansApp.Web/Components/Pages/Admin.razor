@page "/admin"
@using LoansApp.Web.Models
@using LoansApp.Web.Services
@inject LoanService LoanService

<h3>Admin - Aprobar préstamos</h3>

<ul>
    @foreach (var loan in loans)
    {
        <li>
            @loan.Amount - @loan.Status
            <button @onclick="() => Approve(loan.Id)">Aprobar</button>
        </li>
    }
</ul>

@code {
    List<LoanModel> loans = new();

    protected override async Task OnInitializedAsync()
    {
        loans = await LoanService.GetLoans();
    }

    async Task Approve(Guid id)
    {
        await LoanService.ApproveLoan(id);
        loans = await LoanService.GetLoans();
    }
}