@page "/login"
@rendermode InteractiveServer
@using LoansApp.Web.Services
@using System.IdentityModel.Tokens.Jwt
@using System.Security.Claims

@inject AuthService AuthService
@inject NavigationManager Nav
@inject AuthStateService AuthStateService

<h3>Login</h3>

<input @bind="email" placeholder="Email" />
<input @bind="password" type="Password" placeholder="Password" />

<button @onclick="HandleLogin">Login</button>

@code {
    private string email = string.Empty;
    private string password = string.Empty;

    private async Task HandleLogin()
    {
        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
            return;

        var success = await AuthService.Login(email.Trim(), password);

        if (success)
        {
            var token = await AuthService.GetToken();
            bool isAdmin = IsUserAdmin(token ?? "");

            // Redirigimos según el rol del usuario
            if (isAdmin)
            {
                Nav.NavigateTo("/admin", forceLoad: false);
            }
            else
            {
                Nav.NavigateTo("/loans", forceLoad: false);
            }
        }
        else
        {
            Nav.NavigateTo("/error");
        }
    }

    private bool IsUserAdmin(string token)
    {
        if (string.IsNullOrEmpty(token))
            return false;

        try
        {
            var handler = new JwtSecurityTokenHandler();
            var jwt = handler.ReadJwtToken(token);

            var roleClaim = jwt.Claims.FirstOrDefault(c =>
                c.Type == "role" ||
                c.Type.EndsWith("/role") ||
                c.Type == ClaimTypes.Role);

            return roleClaim?.Value?.Equals("Admin", StringComparison.OrdinalIgnoreCase) == true;
        }
        catch
        {
            return false;
        }
    }
}