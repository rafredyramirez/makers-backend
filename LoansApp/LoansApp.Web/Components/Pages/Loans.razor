@page "/loans"
@using LoansApp.Web.Models
@using LoansApp.Web.Services
@rendermode InteractiveServer
@inject LoanService LoanService

<h3>Mis Préstamos</h3>

<button class="btn btn-primary mb-3" @onclick="OpenModal">
    + Nuevo Préstamo
</button>

@if (loans == null)
{
    <p><em>Cargando préstamos...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Monto</th>
                <th>Plazo</th>
                <th>Estado</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var loan in loans)
            {
                <tr>
                    <td>@loan.Amount</td>
                    <td>@loan.Term</td>
                    <td>@loan.Status</td>
                </tr>
            }
        </tbody>
    </table>
}

<!-- MODAL -->
@if (showModal)
{
    <div class="modal-backdrop fade show"></div>

    <div class="modal show d-block">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">Solicitar Préstamo</h5>
                    <button class="btn-close" @onclick="CloseModal"></button>
                </div>

                <div class="modal-body">
                    <div class="mb-3">
                        <label>Monto</label>
                        <input type="number" class="form-control" @bind="amount" />
                    </div>

                    <div class="mb-3">
                        <label>Plazo (meses)</label>
                        <input type="number" class="form-control" @bind="term" />
                    </div>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModal">
                        Cancelar
                    </button>

                    <button class="btn btn-success" @onclick="SubmitLoan">
                        Solicitar
                    </button>
                </div>

            </div>
        </div>
    </div>
}

@code {
    private List<LoanModel> loans = new();

    private bool showModal = false;
    private decimal amount;
    private int term;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadLoans();
        }
    }

    private async Task LoadLoans()
    {
        loans = await LoanService.GetLoans();
        StateHasChanged();
    }

    private void OpenModal()
    {
        amount = 0;
        term = 0;
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private async Task SubmitLoan()
    {
        if (amount <= 0 || term <= 0)
            return;

        await LoanService.RequestLoan(amount, term);

        showModal = false;

        await LoadLoans();
    }
}