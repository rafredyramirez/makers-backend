@rendermode InteractiveServer
@using LoansApp.Web.Services
@using System.IdentityModel.Tokens.Jwt
@using System.Security.Claims
@inject NavigationManager Navigation
@inject AuthService AuthService

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">LoansApp</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />
<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu"></span> Home
            </NavLink>
        </div>

        @if (isAuthenticated)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="loans">
                    <span class="bi bi-cash-stack"></span> Mis Préstamos
                </NavLink>
            </div>
        }

        @if (isAdmin)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="admin">
                    <span class="bi bi-person-badge"></span> Administración
                </NavLink>
            </div>
        }

        @if (!isAuthenticated)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="login">
                    <span class="bi bi-box-arrow-in-right"></span> Login
                </NavLink>
            </div>
        }

        @if (isAuthenticated)
        {
            <div class="nav-item px-3">
                <button class="nav-link btn btn-link text-start" @onclick="Logout">
                    <span class="bi bi-box-arrow-right"></span> Logout
                </button>
            </div>
        }
    </nav>
</div>

@code {
    private bool isAuthenticated = false;
    private bool isAdmin = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadAuthState();
        }
    }

    private async Task LoadAuthState()
    {
        try
        {
            var token = await AuthService.GetToken();

            // Verificamos si el token existe y no está vacío
            isAuthenticated = !string.IsNullOrWhiteSpace(token);

            if (!isAuthenticated)
            {
                isAdmin = false;
                return;
            }

            isAdmin = IsUserInRole(token!, "Admin");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error en LoadAuthState: {ex.Message}");
            isAuthenticated = false;
            isAdmin = false;
        }
    }

    private bool IsUserInRole(string? token, string role)
    {
        if (string.IsNullOrWhiteSpace(token))
            return false;

        try
        {
            var handler = new JwtSecurityTokenHandler();

            if (!handler.CanReadToken(token))
                return false;

            var jwt = handler.ReadJwtToken(token);

            var roleClaim = jwt.Claims.FirstOrDefault(c =>
                c.Type == "role" ||
                c.Type.EndsWith("/role") ||
                c.Type == ClaimTypes.Role);

            return roleClaim?.Value?.Equals(role, StringComparison.OrdinalIgnoreCase) == true;
        }
        catch
        {
            return false;
        }
    }

    private async Task Logout()
    {
        await AuthService.ClearToken();
        isAuthenticated = false;
        isAdmin = false;

        Navigation.NavigateTo("/login", forceLoad: true);
    }

    public async Task RefreshAuthState()
    {
        await LoadAuthState();
        StateHasChanged();
    }
}